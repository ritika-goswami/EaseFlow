import 'package:flutter/material.dart';
import 'package:firebase_core/firebase_core.dart';
import 'package:flutter_dotenv/flutter_dotenv.dart'; // Added for API key management
import 'firebase_options.dart';
import 'screens/splash_screen.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
  // Load the .env file containing your Gemini API Key
  await dotenv.load(fileName: ".env");

  await Firebase.initializeApp(
    options: DefaultFirebaseOptions.currentPlatform,
  );
  
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'EaseFlow',
      theme: ThemeData(
        primaryColor: const Color(0xFFE79AA2),
        colorScheme: ColorScheme.fromSeed(
          seedColor: const Color(0xFFE79AA2),
          primary: const Color(0xFFE79AA2),
        ),
        scaffoldBackgroundColor: Colors.white,
        fontFamily: 'Sans-Serif', 
        useMaterial3: true,
      ),
      // Always start with Splash to show the brand logo
      home: const SplashScreen(), 
    );
  }
}

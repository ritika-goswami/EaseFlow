import 'package:flutter/material.dart';
import 'package:shared_preferences/shared_preferences.dart';
import 'package:easeflow_app/user_data.dart'; // IMPORTED YOUR NEW FILE

class HomeScreen extends StatefulWidget {
  const HomeScreen({super.key});

  @override
  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  bool isFrontSelected = true;
  String selectedHeat = "Off"; 
  String selectedVibration = "Off";
  String selectedDuration = "5 min";
  String selectedVibType = "wave";

  @override
  void initState() {
    super.initState();
    _loadSavedSettings();
  }

  Future<void> _loadSavedSettings() async {
    final prefs = await SharedPreferences.getInstance();
    setState(() {
      isFrontSelected = prefs.getBool('isFront') ?? true;
      selectedHeat = prefs.getString('heatLevel') ?? "Off";
      selectedVibration = prefs.getString('vibLevel') ?? "Off";
      selectedDuration = prefs.getString('heatDuration') ?? "5 min";
      selectedVibType = prefs.getString('vibPattern') ?? "wave";
      // Removed local userName loading because we are using Firebase now
    });
  }

  Future<void> _saveSetting(String key, dynamic value) async {
    final prefs = await SharedPreferences.getInstance();
    if (value is String) await prefs.setString(key, value);
    if (value is bool) await prefs.setBool(key, value);
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.white,
      body: SafeArea(
        child: SingleChildScrollView(
          child: Column(
            children: [
              _buildHeader(),
              const SizedBox(height: 10),
              Container(
                width: 250,
                decoration: BoxDecoration(
                  color: const Color(0xFFF0F0F0),
                  borderRadius: BorderRadius.circular(25),
                ),
                child: Row(
                  children: [
                    Expanded(
                      child: GestureDetector(
                        onTap: () {
                          setState(() => isFrontSelected = true);
                          _saveSetting('isFront', true);
                        },
                        child: _buildToggleButton("Front", isFrontSelected),
                      ),
                    ),
                    Expanded(
                      child: GestureDetector(
                        onTap: () {
                          setState(() => isFrontSelected = false);
                          _saveSetting('isFront', false);
                        },
                        child: _buildToggleButton("Back", !isFrontSelected),
                      ),
                    ),
                  ],
                ),
              ),
              const SizedBox(height: 30),
              _buildTherapyCard(
                "Heat Therapy", 
                "50°C", 
                ["Off", "L", "M", "H"], 
                selectedHeat,
                (val) {
                  setState(() => selectedHeat = val);
                  _saveSetting('heatLevel', val);
                }
              ),
              const SizedBox(height: 20),
              if (isFrontSelected) 
                _buildTherapyCard(
                  "Vibration Therapy", 
                  "", 
                  ["Off", "L", "M", "H"], 
                  selectedVibration,
                  (val) {
                    setState(() => selectedVibration = val);
                    _saveSetting('vibLevel', val);
                  }
                ),
              const SizedBox(height: 100), 
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildHeader() {
    return Padding(
      padding: const EdgeInsets.all(20.0),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceBetween,
        children: [
          Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              // UPDATED: FutureBuilder fetches the name from Firebase
              FutureBuilder<String>(
                future: UserData.getUserName(),
                builder: (context, snapshot) {
                  String displayName = snapshot.data ?? "User";
                  return Text(
                    "Hi, $displayName", 
                    style: const TextStyle(
                      fontSize: 22, 
                      fontWeight: FontWeight.bold, 
                      color: Color(0xFFE79AA2)
                    )
                  );
                },
              ),
              const Text("How are you feeling today?", style: TextStyle(fontSize: 14, fontStyle: FontStyle.italic)),
            ],
          ),
          Hero(
            tag: "profile-image",
            child: Stack(
              children: [
                const CircleAvatar(
                  backgroundColor: Color(0xFFE5D6D6), 
                  child: Icon(Icons.person, color: Colors.black)
                ),
                Positioned(
                  right: 0, 
                  bottom: 0, 
                  child: Container(
                    width: 12, 
                    height: 12, 
                    decoration: BoxDecoration(
                      color: Colors.green, 
                      shape: BoxShape.circle,
                      border: Border.all(color: Colors.white, width: 2),
                    )
                  )
                ),
              ],
            ),
          )
        ],
      ),
    );
  }

  Widget _buildToggleButton(String text, bool isActive) {
    return Container(
      padding: const EdgeInsets.symmetric(vertical: 10),
      decoration: BoxDecoration(
        color: isActive ? const Color(0xFFE5D6D6) : Colors.transparent,
        borderRadius: BorderRadius.circular(25),
      ),
      child: Center(child: Text(text, style: const TextStyle(fontWeight: FontWeight.bold))),
    );
  }

  Widget _buildTherapyCard(String title, String temp, List<String> levels, String currentVal, Function(String) onSelect) {
    bool isHeat = title.contains("Heat");
    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 20),
      padding: const EdgeInsets.all(20),
      decoration: BoxDecoration(
        color: const Color(0xFFFDE4E4),
        borderRadius: BorderRadius.circular(30),
        boxShadow: [BoxShadow(color: Colors.black.withOpacity(0.05), blurRadius: 10, offset: const Offset(0, 5))],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text(title, style: const TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
              if (temp.isNotEmpty) Text(temp, style: const TextStyle(color: Colors.red, fontWeight: FontWeight.bold)),
            ],
          ),
          const SizedBox(height: 15),
          const Text("Intensity", style: TextStyle(color: Colors.grey, fontSize: 12)),
          const SizedBox(height: 10),
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: levels.map((l) {
              bool isSelected = currentVal == l;
              return GestureDetector(
                onTap: () => onSelect(l),
                child: CircleAvatar(
                  radius: 20,
                  backgroundColor: isSelected ? const Color(0xFFE79AA2) : Colors.white,
                  child: Text(l, style: TextStyle(fontSize: 12, color: isSelected ? Colors.white : Colors.black)),
                ),
              );
            }).toList(),
          ),
          const SizedBox(height: 20),
          const Text("Pattern", style: TextStyle(color: Colors.grey, fontSize: 12)),
          const SizedBox(height: 8),
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 12),
            decoration: BoxDecoration(
              color: Colors.white.withOpacity(0.8), 
              borderRadius: BorderRadius.circular(12)
            ),
            child: DropdownButtonHideUnderline(
              child: DropdownButton<String>(
                value: isHeat ? selectedDuration : selectedVibType,
                isExpanded: true,
                icon: const Icon(Icons.arrow_drop_down, color: Colors.grey),
                items: isHeat 
                  ? ['5 min', '10 min', '15 min', 'Continuous'].map((String val) => DropdownMenuItem(value: val, child: Text(val))).toList()
                  : ['wave', 'switching', 'circular'].map((String val) => DropdownMenuItem(value: val, child: Text(val))).toList(),
                onChanged: (newValue) {
                  setState(() {
                    if (isHeat) { 
                      selectedDuration = newValue!; 
                      _saveSetting('heatDuration', newValue);
                    } else { 
                      selectedVibType = newValue!; 
                      _saveSetting('vibPattern', newValue);
                    }
                  });
                },
              ),
            ),
          )
        ],
      ),
    );
  }
}
